# Slack Credentials
# Generate a Slack Bot User OAuth Token with appropriate scopes (channels:read, groups:read, users:read, chat:write, etc.)
SLACK_BOT_TOKEN=your-slack-bot-token-here

# LLM Provider Configuration
# Set to 'gemini', 'openai', or 'local'
LLM_PROVIDER=gemini

# Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Ollama settings (required if LLM_PROVIDER=local)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3
